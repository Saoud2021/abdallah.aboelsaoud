<div class="landing-page">
  <div class="landing-header">
    <h1 class="landing-page-title">{{ section.settings.title }}</h1>
    <p class="landing-page-subtitle">{{ section.settings.subtitle }}</p>
    <button class="landing-page-button">{{ section.settings.button_text }}</button>
  </div>

  <div class="hero-section">
    <div class="hero-top-image">
      <img
        src="{{ 'hero-image.svg' | asset_url }}"
        alt="Festive hero illustration for gift guide showing wrapped presents and seasonal accents with inviting headline text"
        width="600"
        height="400"
      >
    </div>
    <div class="hero-content">
      <h2 class="hero-title">The Gift Guide</h2>
      <p class="hero-description">
        Discover Joy: Your Ultimate Holiday Gift Destination. Explore our curated selection and find the perfect gifts
        to delight your loved ones this holiday season.
      </p>
      <button class="hero-button">Shop Now</button>
    </div>
    <div class="hero-bottom-image">
      <img
        src="{{ 'hero-image.svg' | asset_url }}"
        alt="Secondary holiday-themed illustration with gift and lifestyle elements to support the gift guide"
        width="600"
        height="400"
      >
    </div>
  </div>
  <div class="footer">
    <p class="footer-text">SUSTAINABLE, ETHICALLY MADE CLOTHES IN SIZES XXS TO 6XL</p>
  </div>

  <div class="product-blocks">
    <h1 class="product-blocks-title">Tisso vison in the wild</h1>
    <div class="container">
      {% for block in section.blocks %}
        <div class="product-block">
          {% if block.settings.product %}
             <button
              class="product-block-button"
              type="button"
              aria-label="Quick view {{ p.title | escape }}"
              data-quick-view-trigger
              data-title="{{ p.title | escape }}"
              data-price="{{ p.price | money }}"
              data-url="{{ p.url }}"
              data-image="{% if p.featured_image %}{{ p.featured_image | image_url: width: 600 }}{% endif %}"
            >+</button>
            <a href="{{ block.settings.product.url }}">
              <h3 class="product-block-title">{{ block.settings.product.title }}</h3>
              {% if block.settings.product.featured_image %}
                <img
                  src="{{ block.settings.product.featured_image | image_url: width: 300, height: 300 }}"
                  alt="{{ block.settings.product.featured_image.alt | default: block.settings.product.title }}"
                  width="300"
                  height="300"
                >
              {% else %}
                {{ 'product-1' | placeholder_svg_tag: 'product-block-placeholder' }}
              {% endif %}
            </a>
          {% endif %}
        </div>
      {% endfor %}
    </div>
  </div>
  <div class="quick-view-modal" hidden>
    <div class="quick-view-content">
      <button class="quick-view-close" aria-label="Close quick view modal">&times;</button>
        <h3 class="quick-view-title"></h3>
        <p class="quick-view-price"></p>
        <img class="quick-view-image" src="" alt="" width="300" height="300">
        <a class="quick-view-link" href="">View Product</a>
        <div class="color">{{ block.settings.product.color }} </div>
        <div class="size">{{ block.settings.product.size }} </div>
</div>
</div>

{% stylesheet %}
  .landing-page {
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    align-items: center;
  }
  .landing-header {
    display: flex;
    flex-direction: row;
    justify-content: space-between;
    align-items: center;
    background-color: #f5f5f5;
    width: 100%;
    height: 50px;
    padding: 0px;
    margin: 0px;
  }

  .hero-section {
    display: grid;
    grid-template-columns: 1fr 2fr;
  }
  .hero-top-image {
    grid-column: 1 / -1;
  }

  .hero-top-image img {
    width: 100%;
    height: auto;
  }
  .hero-bottom-image img {
    width: 100%;
    height: auto;
  }
  .footer {
    background-color: #f5f5f5;
    width: 100%;
    height: 50px;
    padding: 0px;
    margin: 0px;
    text-align: center;
  }
  .product-blocks {
    justify-content: space-between;
    align-items: center;
    width: 100%;
    padding: 20px;
  }
  .container {
    display: grid;
    grid-template-columns: 1fr 1fr 1fr;
    gap: 10px;
  }

  .product-block {
    position: relative; /* ← add this: creates a positioning context */
    display: flex;
    flex-direction: column;
    justify-content: start;
    align-items: center;
    border-radius: 5px;
    width: 100%;
    height:500px; /* ← give it a fixed height so "fills the block" means something */
    margin: 10px;
    padding: 0; /* ← remove padding, or the image won't reach the edges */
    overflow: hidden; /* ← clips the image to the rounded corners */
  }
  .product-block img {
    position: absolute; /* ← pulls the image out of normal flow */
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    z-index: 1;
  }
  .product-block-button {
    position: absolute; /* ← pulls the button out of normal flow too */
    top: 8px;
    right: 8px;
    z-index: 2; /* ← sits above the image */
    background-color: #ffffff;
    color: #000000;
    border: none;
    border-radius: 50%;
    padding: 3px 7px;
    cursor: pointer;
  }
{% endstylesheet %}

<script>
  document.addEventListener('DOMContentLoaded', function() {
    const quickViewButtons = document.querySelectorAll('.product-block-button');
    const quickViewModal = document.querySelector('.quick-view-modal');
    const quickViewClose = document.querySelector('.quick-view-close');
    const quickViewTitle = document.querySelector('.quick-view-title');
    const quickViewPrice = document.querySelector('.quick-view-price');
    const quickViewImage = document.querySelector('.quick-view-image');
    const quickViewLink = document.querySelector('.quick-view-link');

    quickViewButtons.forEach(button => {
      button.addEventListener('click', function() {
        const title = this.getAttribute('data-title');
        const price = this.getAttribute('data-price');
        const imageUrl = this.getAttribute('data-image');
        const productUrl = this.getAttribute('data-url');

        quickViewTitle.textContent = title;
        quickViewPrice.textContent = price;
        quickViewImage.src = imageUrl;
        quickViewLink.href = productUrl;

        quickViewModal.hidden = false;
      });
    });

    quickViewClose.addEventListener('click', function() {
      quickViewModal.hidden = true;
    });
  });
  </script>

{% schema %}
{
  "name": "Landing Page",
  "max_blocks": 6,
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Title",
      "default": "Tisso Vision"
    },
    {
      "type": "textarea",
      "id": "subtitle",
      "label": "Subtitle",
      "default": "Find the ideal gift for your loved ones."
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button Text",
      "default": "Choose Gift"
    }
  ],
  "blocks": [
    {
      "type": "product",
      "name": "product Block",
      "settings": [
        {
          "type": "product",
          "id": "product",
          "label": "product"
        }
      ]
    }
  ],
  "presets": []
}
{% endschema %}
