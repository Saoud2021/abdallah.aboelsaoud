<div class="landing-page">
  <div class="landing-header">
    <h1 class="landing-page-title">{{ section.settings.title }}</h1>
    <p class="landing-page-subtitle">{{ section.settings.subtitle }}</p>
    <button class="landing-page-button">{{ section.settings.button_text }}</button>
  </div>

  <div class="hero-section">
    <div class="hero-top-image">
      <img src="{{ 'hero-image.svg' | asset_url }}" alt="Hero bottom Image" width="600" height="400">
    </div>
    <div class="hero-content">
      <h2 class="hero-title">The Gift Guide</h2>
      <p class="hero-description">
        Discover Joy: Your Ultimate Holiday Gift Destination. Explore our curated selection and find the perfect gifts
        to delight your loved ones this holiday season.
      </p>
      <button class="hero-button">Shop Now</button>
    </div>
    <div class="hero-bottom-image">
      <img src="{{ 'hero-image.svg' | asset_url }}" alt="Hero bottom Image" width="600" height="400">
    </div>
  </div>
  <div class="footer">
    <p class="footer-text">SUSTAINABLE, ETHICALLY MADE CLOTHES IN SIZES XXS TO 6XL</p>
  </div>

  <div class="landing-page-blocks">
    {% for block in section.blocks %}
      <div class="landing-page-block">
        {% if block.settings.page %}
          <a href="{{ block.settings.page.url }}">
            <h3 class="landing-page-block-title">{{ block.settings.page.title }}</h3>
          </a>
        {% endif %}
      </div>
    {% endfor %}
  </div>
</div>

{% stylesheet %}
  .landing-page {
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    align-items: center;
  }
  .landing-header {
    display: flex;
    flex-direction: row;
    justify-content: space-between;
    align-items: center;
    background-color: #f5f5f5;
    width: 100%;
    height: 50px;
    padding: 0px;
    margin: 0px;
  }

  .hero-section {
    display: grid;
    grid-template-columns: 1fr 2fr;
  }
  .hero-top-image {
    grid-column: 1 / -1;
  }

  .hero-top-image img {
    width: 100%;
    height: auto;
  }
  .hero-bottom-image img {
    width: 100%;
    height: auto;
  }
  .footer {
    background-color: #f5f5f5;
    width: 100%;
    height: 50px;
    padding: 0px;
    margin: 0px;
    text-align: center;
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Landing Page",
  "max_blocks": 6,
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Title",
      "default": "Tisso Vision"
    },
    {
      "type": "textarea",
      "id": "subtitle",
      "label": "Subtitle",
      "default": "Find the ideal gift for your loved ones."
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button Text",
      "default": "Choose Gift"
    }
  ],
  "blocks": [
    {
      "type": "product",
      "name": "product Block",
      "settings": [
        {
          "type": "product",
          "id": "product",
          "label": "product"
        }
      ]
    }
  ],
  "presets": []
}
{% endschema %}
