<div class="landing-page">
  <div class="landing-header">
    <h1 class="landing-page-title">{{ section.settings.title }}</h1>
    <p class="landing-page-subtitle">{{ section.settings.subtitle }}</p>
    <button class="landing-page-button">{{ section.settings.button_text }}</button>
  </div>

  <div class="hero-section">
    <div class="hero-top-image">
      <img
        src="{{ 'hero-image.svg' | asset_url }}"
        alt="Festive hero illustration for gift guide showing wrapped presents and seasonal accents with inviting headline text"
        width="600"
        height="400"
      >
    </div>
    <div class="hero-content">
      <h2 class="hero-title">The Gift Guide</h2>
      <p class="hero-description">
        Discover Joy: Your Ultimate Holiday Gift Destination. Explore our curated selection and find the perfect gifts
        to delight your loved ones this holiday season.
      </p>
      <button class="hero-button">Shop Now</button>
    </div>
    <div class="hero-bottom-image">
      <img
        src="{{ 'hero-image.svg' | asset_url }}"
        alt="Secondary holiday-themed illustration with gift and lifestyle elements to support the gift guide"
        width="600"
        height="400"
      >
    </div>
  </div>
  <div class="footer">
    <p class="footer-text">SUSTAINABLE, ETHICALLY MADE CLOTHES IN SIZES XXS TO 6XL</p>
  </div>

  <div class="product-blocks">
    <h1 class="product-blocks-title">Tisso vison in the wild</h1>
    <div class="container">
      {% for block in section.blocks %}
        <div class="product-block">
          {% if block.settings.product %}
                        {% assign p = block.settings.product %}

             <button
              class="product-block-button"
              type="button"
              aria-label="Quick view {{ p.title | escape }}"
              data-quick-view-trigger
              data-title="{{ p.title | escape }}"
              data-price="{{ p.price | money }}"
              data-url="{{ p.url }}"
              data-image="{% if p.featured_image %}{{ p.featured_image | image_url: width: 600 }}{% endif %}"
            >+</button>
            <a href="{{ p.url }}">
              <h3 class="product-block-title">{{ p.title }}</h3>
              {% if p.featured_image %}
                <img
                  src="{{ p.featured_image | image_url: width: 300, height: 300 }}"
                  alt="{{ p.featured_image.alt | default: p.title }}"
                  width="300"
                  height="300"
                >
              {% else %}
                {{ 'product-1' | placeholder_svg_tag: 'product-block-placeholder' }}
              {% endif %}
            </a>
          {% endif %}
        </div>
      {% endfor %}
    </div>
  </div>
  <div class="quick-view-modal" hidden>
    <div class="quick-view-content">
      <button class="quick-view-close" aria-label="Close quick view modal">&times;</button>
        <h3 class="quick-view-title"></h3>
        <p class="quick-view-price"></p>
        <img class="quick-view-image" src="" alt="" width="300" height="300">
        <div class="color">{{ p.selected_or_first_available_variant.option1 }}</div>
        <div class="size">{{ p.selected_or_first_available_variant.option2 }}</div>
        <button class="quick-view-add-to-cart">Add to Cart</button>
</div>
</div>

{% stylesheet %}
  .landing-page {
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    align-items: center;
  }
  .landing-header {
    display: flex;
    flex-direction: row;
    justify-content: space-between;
    align-items: center;
    background-color: #f5f5f5;
    width: 100%;
    height: 50px;
    padding: 0px;
    margin: 0px;
  }

  .hero-section {
    display: grid;
    grid-template-columns: 1fr 2fr;
  }
  .hero-top-image {
    grid-column: 1 / -1;
  }

  .hero-top-image img {
    width: 100%;
    height: auto;
  }
  .hero-bottom-image img {
    width: 100%;
    height: auto;
  }
  .footer {
    background-color: #f5f5f5;
    width: 100%;
    height: 50px;
    padding: 0px;
    margin: 0px;
    text-align: center;
  }
  .product-blocks {
    justify-content: space-between;
    align-items: center;
    width: 100%;
    padding: 20px;
  }
  .container {
    display: grid;
    grid-template-columns: 1fr 1fr 1fr;
    gap: 10px;
  }

  .product-block {
    position: relative; /* ← add this: creates a positioning context */
    display: flex;
    flex-direction: column;
    justify-content: start;
    align-items: center;
    border-radius: 5px;
    width: 100%;
    height:500px; /* ← give it a fixed height so "fills the block" means something */
    margin: 10px;
    padding: 0; /* ← remove padding, or the image won't reach the edges */
    overflow: hidden; /* ← clips the image to the rounded corners */
  }
  .product-block img {
    position: absolute; /* ← pulls the image out of normal flow */
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    z-index: 1;
  }
  .product-block-button {
    position: absolute; /* ← pulls the button out of normal flow too */
    top: 8px;
    right: 8px;
    z-index: 2; /* ← sits above the image */
    background-color: #ffffff;
    color: #000000;
    border: none;
    border-radius: 50%;
    padding: 3px 7px;
    cursor: pointer;
  }
   /* --- Quick view popup --- */
  .quick-view-overlay {
    position: fixed;
    inset: 0;
    background: rgba(0, 0, 0, 0.5);
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 100;
  }
  .quick-view-overlay[hidden] {
    display: none;
  }
  .quick-view-modal {
    position: relative;
    background: #ffffff;
    border-radius: 8px;
    padding: 24px;
    width: 90%;
    max-width: 400px;
    max-height: 85vh;
    overflow-y: auto;
    text-align: center;
  }
  .quick-view-close {
    position: absolute;
    top: 8px;
    right: 8px;
    background: none;
    border: none;
    font-size: 24px;
    line-height: 1;
    cursor: pointer;
  }
  .quick-view-image {
    width: 100%;
    height: auto;
    border-radius: 6px;
    margin-bottom: 16px;
  }
  .quick-view-price {
    font-weight: 600;
    margin: 8px 0 12px;
  }
  .quick-view-color,
  .quick-view-size {
    font-size: 14px;
    color: #555;
  }
  .quick-view-link {
    display: inline-block;
    margin-top: 16px;
    padding: 10px 20px;
    background: #000000;
    color: #ffffff;
    text-decoration: none;
    border-radius: 4px;
  }
{% endstylesheet %}

<script>
 (function () {
    // Scope to this specific section instance, so multiple copies of this
    // section on one page don't share (and fight over) the same modal.
    var root = document.currentScript.closest('.landing-page');
    if (!root) return;

    var container = root.querySelector('[data-quick-view-container]');
    var overlay = root.querySelector('[data-quick-view-overlay]');
    var img = root.querySelector('[data-quick-view-image]');
    var titleEl = root.querySelector('[data-quick-view-title]');
    var priceEl = root.querySelector('[data-quick-view-price]');
    var colorEl = root.querySelector('[data-quick-view-color]');
    var sizeEl = root.querySelector('[data-quick-view-size]');
    var link = root.querySelector('[data-quick-view-link]');
    var closeBtn = root.querySelector('[data-quick-view-close]');

    function openPopup(trigger) {
      img.src = trigger.dataset.image || '';
      img.alt = trigger.dataset.title || '';
      titleEl.textContent = trigger.dataset.title || '';
      priceEl.textContent = trigger.dataset.price || '';
      colorEl.textContent = trigger.dataset.color ? 'Color: ' + trigger.dataset.color : '';
      sizeEl.textContent = trigger.dataset.size ? 'Size: ' + trigger.dataset.size : '';
      link.href = trigger.dataset.url || '#';
      overlay.hidden = false;
    }

    function closePopup() {
      overlay.hidden = true;
    }

    // ONE listener on the container, delegated to every current AND future
    // .product-block-button — this is what survives theme-editor re-renders.
    container.addEventListener('click', function (event) {
      var trigger = event.target.closest('[data-quick-view-trigger]');
      if (!trigger) return;
      event.preventDefault();
      openPopup(trigger);
    });

    closeBtn.addEventListener('click', closePopup);

    overlay.addEventListener('click', function (event) {
      if (event.target === overlay) closePopup();
    });

    document.addEventListener('keydown', function (event) {
      if (event.key === 'Escape' && !overlay.hidden) closePopup();
    });
  })();
  </script>

{% schema %}
{
  "name": "Landing Page",
  "max_blocks": 6,
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Title",
      "default": "Tisso Vision"
    },
    {
      "type": "textarea",
      "id": "subtitle",
      "label": "Subtitle",
      "default": "Find the ideal gift for your loved ones."
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button Text",
      "default": "Choose Gift"
    }
  ],
  "blocks": [
    {
      "type": "product",
      "name": "product Block",
      "settings": [
        {
          "type": "product",
          "id": "product",
          "label": "product"
        }
      ]
    }
  ],
  "presets": []
}
{% endschema %}
