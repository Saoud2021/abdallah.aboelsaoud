<div class="landing-page">
  <div class="landing-header">
    <h1 class="landing-page-title">{{ section.settings.title }}</h1>
    <p class="landing-page-subtitle">{{ section.settings.subtitle }}</p>
    <button class="landing-page-button">{{ section.settings.button_text }}</button>
  </div>

  <div class="hero-section">
    <div class="hero-top-image">
      <img src="{{ 'hero-image.svg' | asset_url }}" alt="Hero bottom Image" width="600" height="400">
    </div>
    <div class="hero-content">
      <h2 class="hero-title">The Gift Guide</h2>
      <p class="hero-description">
        Discover Joy: Your Ultimate Holiday Gift Destination. Explore our curated selection and find the perfect gifts
        to delight your loved ones this holiday season.
      </p>
      <button class="hero-button">Shop Now</button>
    </div>
    <div class="hero-bottom-image">
      <img src="{{ 'hero-image.svg' | asset_url }}" alt="Hero bottom Image" width="600" height="400">
    </div>
  </div>
  <div class="footer">
    <p class="footer-text">SUSTAINABLE, ETHICALLY MADE CLOTHES IN SIZES XXS TO 6XL</p>
  </div>

  <div class="product-blocks">
    <h3 class="product-blocks-title">Tisso vison in the wild</h3>
    <div class="container">
      {% for block in section.blocks %}
        <div class="product-block">
          {% if block.settings.product %}
          <button class="product-block-button">+</button>
            <a href="{{ block.settings.product.url }}">
              <h3 class="product-block-title">{{ block.settings.product.title }}</h3>
            </a>
          {% endif %}
        </div>
      {% endfor %}
    </div>
  </div>
</div>

{% stylesheet %}
  .landing-page {
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    align-items: center;
  }
  .landing-header {
    display: flex;
    flex-direction: row;
    justify-content: space-between;
    align-items: center;
    background-color: #f5f5f5;
    width: 100%;
    height: 50px;
    padding: 0px;
    margin: 0px;
  }

  .hero-section {
    display: grid;
    grid-template-columns: 1fr 2fr;
  }
  .hero-top-image {
    grid-column: 1 / -1;
  }

  .hero-top-image img {
    width: 100%;
    height: auto;
  }
  .hero-bottom-image img {
    width: 100%;
    height: auto;
  }
  .footer {
    background-color: #f5f5f5;
    width: 100%;
    height: 50px;
    padding: 0px;
    margin: 0px;
    text-align: center;
  }
  .product-blocks {
    justify-content: space-between;
    align-items: center;
    width: 100%;
  }
  .container {
    display: grid;
    grid-template-columns: 1fr 1fr 1fr;
    gap: 10px;
  }

  .product-block {
    display: flex;
    flex-direction: column;
    justify-content: start;
    align-items: center;
    border-radius: 5px;
    width: 100%;
    height: 100px;
    background-color: #d1d1d1;
    margin: 10px;
    padding: 10px;
  }
  .product-block-button {
    background-color: #ffffff;
    color: #000000;
    border: none;
    border-radius: 50%;
    padding: 3px 7px;
    cursor: pointer;
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Landing Page",
  "max_blocks": 6,
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Title",
      "default": "Tisso Vision"
    },
    {
      "type": "textarea",
      "id": "subtitle",
      "label": "Subtitle",
      "default": "Find the ideal gift for your loved ones."
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button Text",
      "default": "Choose Gift"
    }
  ],
  "blocks": [
    {
      "type": "product",
      "name": "product Block",
      "settings": [
        {
          "type": "product",
          "id": "product",
          "label": "product"
        }
      ]
    }
  ],
  "presets": []
}
{% endschema %}
